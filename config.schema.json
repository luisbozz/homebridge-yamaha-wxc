{
  "pluginAlias": "YamahaWxcWxa50",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "Homebridge plugin for Yamaha WXC-50 and WXA-50",
  "footerDisplay": "Focused fork for Yamaha WXC-50 / WXA-50",
  "schema": {
    "type": "object",
    "properties": {
      "statePollingInterval": {
        "title": "Status Polling Interval in Seconds",
        "description": "Time in seconds between each status polling cycle",
        "default": 30,
        "type": "integer",
        "minimum": 3,
        "maximum": 300
      },
      "debug": {
        "title": "Enable Debug Logs",
        "description": "When checked, the plugin will produce extra logs for debugging purposes",
        "type": "boolean",
        "default": false,
        "required": false
      },
      "receivers": {
        "type": "array",
        "required": false,
        "items": {
          "title": "WXC-50 / WXA-50 Devices",
          "type": "object",
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "required": true
            },
            "ip": {
              "title": "IP Address (IPv4)",
              "type": "string",
              "required": true
            },
            "volumeAccessory": {
              "title": "External Volume Accessory",
              "description": "Extra accessory for easier volume control",
              "type": "string",
              "required": false,
              "oneOf": [
                {
                  "title": "Fan",
                  "enum": [
                    "fan"
                  ]
                },
                {
                  "title": "Light Bulb",
                  "enum": [
                    "bulb"
                  ]
                }
              ]
            },
            "minVolume": {
              "title": "Min Volume",
              "description": "Adjust if the minimum volume in HomeKit is too high or too low",
              "default": -80,
              "type": "integer",
              "minimum": -100,
              "maximum": 100
            },
            "maxVolume": {
              "title": "Max Volume",
              "description": "Adjust if the maximum volume in HomeKit is too high or too low",
              "default": -10,
              "type": "integer",
              "minimum": -100,
              "maximum": 100
            }
          }
        }
      }
    }
  },
  "layout": [
    {
      "key": "statePollingInterval"
    },
    {
      "key": "debug"
    },
    {
      "key": "receivers",
      "type": "array",
      "title": "WXC-50 / WXA-50 Devices",
      "orderable": false,
      "buttonText": "Add Device",
      "expandable": true,
      "expanded": true,
      "items": [
        {
          "type": "section",
          "expandable": false,
          "title": "Configuration",
          "items": [
            "receivers[].name",
            "receivers[].ip",
            "receivers[].volumeAccessory",
            "receivers[].minVolume",
            "receivers[].maxVolume"
          ]
        }
      ]
    }
  ]
}
